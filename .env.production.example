# ===============================
# 生产环境示例（请按需复制成 .env.production）
# ===============================

# 前端：统一从这个基地址发起请求
VITE_API_BASE_URL=/api
VITE_API_HEALTH_PATH=/healthz

# 给前端开发用的代理目标（不一定在生产需要；生产由 server/index.ts 使用下面的 API_PROXY_TARGET）
VITE_API_PROXY_TARGET=http://localhost:8080

# 给生产 Node 服务端用的代理目标：
# - 你的后端真实地址，例如：http://your-backend:8080 或 https://api.example.com
API_PROXY_TARGET=http://localhost:8080

# stripPrefix=false 表示保留 /api 前缀转发：
# - 例如：前端 /api/users -> 后端 /api/users
# stripPrefix=true 表示去掉 /api 前缀：
# - 例如：前端 /api/users -> 后端 /users
API_PROXY_STRIP_PREFIX=true

# 服务端端口（容器/平台会覆盖这个值也可以）
PORT=3000

