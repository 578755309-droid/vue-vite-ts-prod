# ===============================
# 通用环境变量模板（本地开发/联调）
# ===============================

# 前端调用后端的基地址：
# - 如果你使用同源部署（Node server 同时代理 /api），推荐直接填 `/api`
VITE_API_BASE_URL=/api

# 后端健康检查路径（相对于 VITE_API_BASE_URL）
VITE_API_HEALTH_PATH=/healthz

# Vite 开发服务器使用：将 /api 转发到真实后端（避免 CORS）
VITE_API_PROXY_TARGET=http://localhost:8080

